datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

model SystemSettings {
  id             String   @id @default("default")
  gtmId          String?  // ID do Google Tag Manager (ex: GTM-XXXXXX)
  openingTime    String   @default("09:00") // Horário de abertura (HH:MM)
  closingTime    String   @default("19:00") // Horário de fechamento (HH:MM)
  adminPassword  String   @default("admin123") // Senha de acesso ao painel admin
  barberShopName String   @default("Barbearia Premium") // Nome da barbearia
  logoUrl        String   @default("") // Link do logotipo da barbearia
  address        String   @default("Av. Paulista, 1000 - Bela Vista, São Paulo - SP") // Endereço físico
  phone          String   @default("(11) 99999-9999") // Telefone de contato
  evolutionUrl   String?  @default("") // URL base da Evolution API
  evolutionApiKey String? @default("") // Chave de acesso apikey da Evolution
  evolutionInstance String? @default("") // Nome da instância do WhatsApp no servidor
  whatsappConfirmationEnabled  Boolean  @default(true) // Se a mensagem de confirmação de agendamento está ativa
  whatsappConfirmationTemplate String   @default("Olá, *{cliente}*! Seu agendamento de *{servico}* com o profissional *{barbeiro}* foi confirmado para o dia *{data}* às *{horario}*. Valor: *{valor}*. Esperamos você!") // Template de confirmação
  whatsappReengagementEnabled  Boolean  @default(false) // Se o reengajamento pós-agendamento de retorno está ativo
  whatsappReengagementDays     Int      @default(30) // Dias de ausência para reengajamento
  whatsappReengagementTemplate String   @default("Olá, *{cliente}*! Faz *{dias}* dias desde o seu último serviço de *{servico}* com a gente. Que tal agendar um novo horário para manter o visual em dia? Agende no link: {link_app}") // Template de reengajamento
  googleMapsEmbedUrl           String?  @default("") // URL de incorporação do Google Maps
  googleReviewsWidget          String?  @default("") // Código do widget de reviews de terceiros
  googleRating                 Float?   @default(0) // Nota média pública do Google Meu Negócio
  googleReviewsCount           Int      @default(0) // Quantidade pública de avaliações no Google
  colorAccentGold              String   @default("#c5a880") // Cor principal de destaque da marca
  colorBgPrimary               String   @default("#0a0a0c") // Fundo principal do tema
  colorBgSecondary             String   @default("#121216") // Fundo secundário do tema
  colorBgTertiary              String   @default("#1b1b22") // Fundo terciário do tema
  updatedAt      DateTime @updatedAt
}

model Barber {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  openingTime     String    @default("09:00")
  closingTime     String    @default("19:00")
  lunchStart      String    @default("12:00") // Início do almoço (HH:MM)
  lunchEnd        String    @default("13:00") // Fim do almoço (HH:MM)
  workDays        String    @default("1,2,3,4,5,6") // Dias de atendimento (0=Dom, 1=Seg, ..., 6=Sáb)
  services        Service[] @relation("BarberServices")
  bookings        Booking[]
  blocks          BarberBlock[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Service {
  id          String   @id @default(uuid())
  name        String
  price       Float
  duration    Int      // Duração em minutos
  barbers     Barber[] @relation("BarberServices")
  bookings    Booking[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Booking {
  id            String   @id @default(uuid())
  clientName    String
  clientEmail   String
  clientPhone   String
  dateTime      DateTime
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  barberId      String
  barber        Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  googleEventId String?  // ID do evento criado no Google Calendar
  reengagementSent Boolean @default(false) // Indica se o lembrete de reengajamento já foi enviado para este agendamento
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BarberBlock {
  id        String   @id @default(uuid())
  barberId  String
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  date      DateTime // Data do bloqueio (armazena o dia sem componente de hora)
  startTime String   // "HH:MM" de início do bloqueio (ex: "14:00")
  endTime   String   // "HH:MM" de fim do bloqueio (ex: "15:00")
  reason    String?  // Motivo opcional (ex: "Consulta médica")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id         String   @id @default(uuid())
  authorName String
  rating     Int      @default(5)
  content    String
  avatarUrl  String?  @default("")
  source     String   @default("Google")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
