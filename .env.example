# ==============================================================================
# CONFIGURAÇÕES DE AMBIENTE - APP DE AGENDAMENTO DE BARBEARIA
# Copie este arquivo para .env e preencha as credenciais.
# ==============================================================================

# URL de Conexão com o Supabase (PostgreSQL)
# Obtenha na sua conta Supabase em Project Settings > Database > Connection string > URI (lembre de usar a porta 5432 padrão)
DATABASE_URL="postgresql://postgres:[SENHA_DO_BANCO]@db.[ID_DO_PROJETO].supabase.co:5432/postgres?schema=public"

# ------------------------------------------------------------------------------
# CREDENCIAIS DO GOOGLE CLOUD OAUTH 2.0
# Geradas no painel: https://console.cloud.google.com/
# Siga as etapas descritas no arquivo GUIA_GOOGLE_CLOUD.md
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID="seu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="sua-chave-secreta-do-google-client"

# URI de Redirecionamento da API de Callback do Google OAuth:
# - Desenvolvimento local: "http://localhost:3000/api/auth/google/callback"
# - Produção (Vercel): "https://seu-dominio-na-vercel.vercel.app/api/auth/google/callback"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# ------------------------------------------------------------------------------
# CONFIGURAÇÕES DO APLICATIVO
# ------------------------------------------------------------------------------

# URL Base do Aplicativo:
# - Desenvolvimento local: "http://localhost:3000"
# - Produção (Vercel): "https://seu-dominio-na-vercel.vercel.app"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Senha Master Administrativa para acesso ao painel (/admin):
# Escolha uma senha segura para o acesso do administrador da barbearia.
ADMIN_PASSWORD="admin123"
